modules = ["python-3.12", "nodejs-20", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "poppler_utils", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GitHub Auto-Sync"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sh -c 'cd backend && uvicorn app.main:app --host 127.0.0.1 --port 8000'"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sh -c 'cd frontend && npm run dev'"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "GitHub Auto-Sync"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/install-git-hooks.sh && echo '[auto-sync] Hook active. Pushing now, then every 30 min.' && bash scripts/auto-push-github.sh || true; while true; do sleep 1800; bash scripts/auto-push-github.sh || true; done"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000
exposeLocalhost = true

[deployment]
deploymentTarget = "vm"
run = ["sh", "-c", "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 5000"]
build = ["sh", "-c", "cd frontend && npm install && npm run build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 90000
